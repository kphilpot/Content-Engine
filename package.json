{
  "name": "content-engine-browser-automation",
  "version": "2.0.0",
  "description": "Browser automation-powered content engine for multi-channel social media publishing",
  "main": "engine/weekly_cycle.js",
  "type": "commonjs",
  "scripts": {
    "test": "node --test --test-isolation=none",
    "validate": "node scripts/validate_setup.js",
    "run:orchestrator": "node scripts/run_orchestrator.js",
    "run:cycle": "node scripts/run_weekly_cycle.js",
    "start:backend": "node browser-automation/browser_backend.js",
    "dev": "concurrently \"npm run start:backend\" \"npm run run:cycle\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "playwright": "^1.40.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}
